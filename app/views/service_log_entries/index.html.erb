<div class="container py-4">
  <div class="d-flex justify-content-between align-items-center mb-4">
    <div>
      <h1 class="mb-1">Service History</h1>
      <p class="text-muted mb-0"><%= @vehicle.year %> <%= @vehicle.make %> <%= @vehicle.model %></p>
    </div>
    <%= link_to "Log Service Entry", new_vehicle_service_log_entry_path(@vehicle), class: "btn btn-primary" %>
  </div>

  <% if @entries.any? %>
    <div class="table-responsive">
      <table class="table table-striped align-middle">
        <thead>
          <tr>
            <th>Date</th>
            <th>Service Type</th>
            <th>Mileage</th>
            <th>Service Center</th>
            <th>Parts</th>
            <th>Labour</th>
            <th>Notes</th>
            <th>Actions</th>
          </tr>
        </thead>
        <tbody>
          <% @entries.each do |entry| %>
            <tr>
              <td><%= entry.serviced_on.strftime('%d %b %Y') %></td>
              <td><%= entry.service_type.name %></td>
              <td><%= number_with_delimiter(entry.mileage_at_service) %> km</td>
              <td><%= entry.service_center %></td>
              <td><%= number_to_currency(entry.parts_cost, unit: "MDL") %></td>
              <td><%= number_to_currency(entry.labour_cost, unit: "MDL") %></td>
              <td><%= entry.notes %></td>
              <td>
                <%= link_to "Edit", edit_vehicle_service_log_entry_path(@vehicle, entry),
                      class: "btn btn-sm btn-outline-secondary" %>
                <%= button_to "Delete", vehicle_service_log_entry_path(@vehicle, entry),
                      method: :delete,
                      data: { turbo_confirm: "Delete this service entry?" },
                      class: "btn btn-sm btn-outline-danger ms-1",
                      form: { style: "display:inline" } %>
              </td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
  <% else %>
    <div class="text-center py-5">
      <p class="text-muted fs-5">No service entries yet.</p>
      <%= link_to "Log your first service entry", new_vehicle_service_log_entry_path(@vehicle), class: "btn btn-primary" %>
    </div>
  <% end %>

  <%= link_to "← Back to Vehicle", vehicle_path(@vehicle), class: "btn btn-outline-secondary mt-3" %>
</div>
