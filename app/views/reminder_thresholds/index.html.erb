<div class="container py-4">
  <h1 class="mb-1">Reminder Thresholds</h1>
  <p class="text-muted mb-4">
    <%= @vehicle.year %> <%= @vehicle.make %> <%= @vehicle.model %>
  </p>

  <div class="table-responsive">
    <table class="table align-middle">
      <thead>
        <tr>
          <th>Service Type</th>
          <th>Mileage Interval</th>
          <th>Time Interval</th>
          <th>Actions</th>
        </tr>
      </thead>
      <tbody>
        <% @thresholds_by_service_type.each do |service_type, threshold| %>
          <tr>
            <td><%= service_type.name %></td>
            <% if threshold %>
              <td>
                <%= threshold.mileage_interval ? "#{number_with_delimiter(threshold.mileage_interval)} km" : "—" %>
              </td>
              <td>
                <%= threshold.time_interval_months ? "#{threshold.time_interval_months} months" : "—" %>
              </td>
              <td>
                <%= link_to "Edit", edit_vehicle_reminder_threshold_path(@vehicle, threshold),
                      class: "btn btn-sm btn-outline-primary me-1" %>
                <%= button_to "Remove", vehicle_reminder_threshold_path(@vehicle, threshold),
                      method: :delete,
                      class: "btn btn-sm btn-outline-danger",
                      data: { turbo_confirm: "Remove this threshold?" } %>
              </td>
            <% else %>
              <td class="text-muted" colspan="2">Not configured</td>
              <td>
                <%= link_to "Configure",
                      new_vehicle_reminder_threshold_path(@vehicle, service_type_id: service_type.id),
                      class: "btn btn-sm btn-outline-secondary" %>
              </td>
            <% end %>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>

  <%= link_to "← Back to Vehicle", @vehicle, class: "btn btn-outline-secondary" %>
</div>
